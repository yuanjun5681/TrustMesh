# HTTP
PORT=8080
ALLOW_ALL_CORS=true
READ_TIMEOUT=10s
WRITE_TIMEOUT=15s
SHUTDOWN_GRACE=8s
HEARTBEAT_TTL=30s
HEARTBEAT_SWEEP_INTERVAL=5s

# Auth
JWT_SECRET=trustmesh-dev-secret
TOKEN_TTL=24h

# Logging
LOG_LEVEL=info

# MongoDB
MONGO_ENABLED=true
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=trustmesh
MONGO_TIMEOUT=5s

# NATS
NATS_ENABLED=true
NATS_URL=nats://127.0.0.1:4222
NATS_CLIENT_NAME=trustmesh-backend
NATS_TIMEOUT=3s
