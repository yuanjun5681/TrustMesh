# HTTP
PORT=8080
ALLOW_ALL_CORS=true
READ_TIMEOUT=10s
WRITE_TIMEOUT=15s
SHUTDOWN_GRACE=8s

# Auth
JWT_SECRET=trustmesh-dev-secret
TOKEN_TTL=24h

# Logging
LOG_LEVEL=info

# MongoDB
MONGO_ENABLED=true
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DATABASE=trustmesh
MONGO_TIMEOUT=5s

# ClawSynapse
CLAWSYNAPSE_API_URL=http://127.0.0.1:18080
CLAWSYNAPSE_NODE_ID=trustmesh-server
CLAWSYNAPSE_TIMEOUT=3s
CLAWSYNAPSE_PEER_SYNC_INTERVAL=10s
